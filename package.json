{
  "name": "sota-peak-finder",
  "version": "3.7.0",
  "type": "module",
  "description": "SOTA Peak Finder: Find nearby summits worldwide with GPS. 179,000+ SOTA summits with references, points, altitude, and distance. Fully offline PWA for activators.",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:sota": "bun scripts/build-sota-database.mjs",
    "build:sitemaps": "bun scripts/generate-summit-sitemap.mjs",
    "build:all": "bun run build:sota && bun run build:sitemaps && bun run build",
    "setup": "bun scripts/setup-dev-database.ts",
    "preview": "vite preview",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "lint": "biome check --diagnostic-level=error .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "knip": "knip",
    "lighthouse": "NODE_OPTIONS='--no-deprecation' lhci autorun",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/bun": "latest",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "husky": "^9.1.7",
    "knip": "^6.1.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.8",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.2",
    "workbox-window": "^7.4.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@sqlite.org/sqlite-wasm": "^3.51.2-build8",
    "esbuild": "^0.27.4",
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^2.0.5",
    "react-i18next": "^16.5.8",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.13.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "biome check --write"
    ]
  }
}
